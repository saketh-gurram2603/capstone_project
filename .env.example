# ── Copy this to backend/env/development.env and fill in your values ──────────
# NEVER commit the real .env file — only this template.

# OpenAI
OPENAI_API_KEY=sk-...

# Tavily (L2 web search) — free tier at https://tavily.com
TAVILY_API_KEY=tvly-...

# Postgres
POSTGRES_USER=incident_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=incident_kb

# Qdrant (leave blank for no auth in local dev)
QDRANT_API_KEY=

# Redis (leave blank for no auth in local dev)
REDIS_PASSWORD=

# App
SECRET_KEY=generate-a-random-string-here
